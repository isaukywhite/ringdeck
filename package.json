{
  "name": "ringdeck",
  "description": "A radial action launcher for power users",
  "author": "isaukywhite",
  "private": true,
  "version": "0.2.2",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite build && electron .",
    "build": "vite build && electron-builder",
    "pack": "vite build && electron-builder --dir",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^35",
    "electron-builder": "^26",
    "jsdom": "^29.0.0",
    "vite": "^6",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "com.ringdeck.app",
    "productName": "RingDeck",
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Utility"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "logo_ring_2_1.png"
    ],
    "directories": {
      "output": "out"
    }
  },
  "dependencies": {
    "heroicons": "^2.2.0",
    "uiohook-napi": "^1.5.5"
  }
}
